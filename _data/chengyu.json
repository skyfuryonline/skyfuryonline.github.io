        "num": 1,
        "idiom": "浅尝辄止",
        "definition": "只略微尝试一下就停止。比喻做事不求深入。"
      },
      {
        "num": 2,
        "idiom": "不求甚解",
        "definition": "原指读书只领会要旨，不必在一字一句上下功夫。后指只求懂个大概，不去深入理会。"
      },
      {
        "num": 3,
        "idiom": "囫囵吞枣",
        "definition": "比喻笼统地接受，不加分析、甄别，不求甚解。"
      },
      {
        "num": 4,
        "idiom": "融会贯通",
        "definition": "指把各方面的知识、道理融合贯穿，从而获得对事物全面、透彻地理解和领悟。"
      },
      {
        "num": 5,
        "idiom": "举一反三",
        "definition": "指举出一件事，就可以触类旁通，类推出许多同类事物来。"
      },
      {
        "num": 6,
        "idiom": "触类旁通",
        "definition": "指掌握了某一事物的规律或知识，就能够以此类推，了解同类的其他事物。"
      },
      {
        "num": 7,
        "idiom": "相辅相成",
        "definition": "指两种事物互相辅助，互相促成，缺一不可。"
      },
      {
        "num": 8,
        "idiom": "相得益彰",
        "definition": "两个人或两件事相互配合，双方的能力和作用更能显示出来。"
      }
    ],
